<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FirstFragment">

    <View
        android:id="@+id/top_strip"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/purple_strip"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/close_app_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_close"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/top_strip"
        app:layout_constraintBottom_toBottomOf="@+id/top_strip"
        android:contentDescription="Close application" />

    <ImageView
        android:id="@+id/language_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_planet"
        android:padding="12dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/top_strip"
        app:layout_constraintBottom_toBottomOf="@+id/top_strip"
        android:contentDescription="Language selection" />

    <ImageView
        android:id="@+id/water_drop"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@drawable/drop_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.259"
        android:contentDescription="Water drop icon" />

    <TextView
        android:id="@+id/water_count_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 ml"
        android:textColor="@color/light_gray"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/water_drop"
        app:layout_constraintEnd_toEndOf="@+id/water_drop"
        app:layout_constraintStart_toStartOf="@+id/water_drop"
        app:layout_constraintTop_toTopOf="@+id/water_drop"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/daily_goal_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dzienny cel: 2000 ml"
        android:textColor="@color/water_blue"
        android:textSize="18sp"
        android:textStyle="italic"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/water_drop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/daily_goal_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/add_250_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ 250 ml"
            android:textColor="@android:color/white"
            android:background="@drawable/button_rounded"
            android:padding="16dp"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/add_500_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ 500 ml"
            android:textColor="@android:color/white"
            android:background="@drawable/button_rounded"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/reset_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_reset"
        android:layout_marginTop="32dp"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@+id/button_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Reset water counter" />

    <View
        android:id="@+id/bottom_strip"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/purple_strip"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/chart_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_chart"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/bottom_strip"
        app:layout_constraintBottom_toBottomOf="@+id/bottom_strip"
        android:contentDescription="View statistics" />

    <ImageView
        android:id="@+id/person_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="User profile"
        android:focusable="true"
        android:padding="12dp"
        android:src="@drawable/ic_person"
        app:layout_constraintBottom_toBottomOf="@+id/bottom_strip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.955"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/bottom_strip" />

</androidx.constraintlayout.widget.ConstraintLayout>